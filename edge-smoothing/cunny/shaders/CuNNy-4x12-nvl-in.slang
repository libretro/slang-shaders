        result += mul(s0_2_0, M3x4(-4.618e-03, 7.533e-02, 3.191e-04, 2.329e-02, -5.662e-03, 2.104e-01, -1.219e-02, -5.316e-02, 4.399e-03, 8.012e-03, 9.658e-03, -4.013e-03));
        result += mul(s0_2_1, M3x4(-1.724e-03, 5.198e-03, 1.529e-03, -2.257e-02, 3.968e-03, 5.456e-02, 6.396e-02, 1.018e-01, 1.426e-03, -8.712e-03, 7.497e-03, 2.531e-02));
