        result += V4(2.371e-02, 1.429e-03, -1.518e-03, -1.126e-03);
        result = max(result, 0.0);
    }
    else if (phase_index == 1)
    {
        s0_0_0 = L0(-1.0, -1.0);
        s0_0_1 = L0(0.0, -1.0);
