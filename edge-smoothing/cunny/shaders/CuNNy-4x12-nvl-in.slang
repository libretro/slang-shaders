        result += mul(s0_0_2, M3x4(-5.411e-03, -1.579e-02, 6.164e-05, 3.549e-03, -1.140e-03, -7.766e-02, -1.922e-02, -2.055e-02, -3.550e-03, 1.331e-02, 1.014e-03, -1.736e-03));
