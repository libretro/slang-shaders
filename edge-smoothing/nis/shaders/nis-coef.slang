void main() {
    ivec2 xy = ivec2(vTexCoord * params.OutputSize.xy);
    int tap = clamp(xy.x, 0, 5);
    int phase = xy.y;
    float v = (phase < 64) ? coefScaler[phase * 6 + tap] : coefUSM[(phase - 64) * 6 + tap];
    FragColor = vec4(v, 0.0, 0.0, 0.0);
}
